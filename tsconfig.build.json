{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "emitDeclarationOnly": true,
        "declaration": true,
        "declarationDir": "dist/types",
        "types": ["node"]
    },
    "include": ["src"],
    "exclude": [
        "src/**/*.test.ts",
        "src/**/*.test.tsx",
        "src/**/*.spec.ts",
        "src/**/*.spec.tsx",
        "test",
        "vitest.config.ts",
        "demo",
        "node_modules",
        "dist"
    ]
}
